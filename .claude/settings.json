{
  "permissions": {
	"allow": [
	  "Bash(mkdir:*)",
	  "Bash(touch:*)",
	  "Bash(ls:*)",
	  "Bash(cat:*)",
	  "Bash(npm run dev:*)",
	  "Bash(npm run build:*)",
